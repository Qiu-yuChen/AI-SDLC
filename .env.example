# LLM API Keys (at least one required)
DEEPSEEK_API_KEY=sk-your-deepseek-key
OPENAI_API_KEY=sk-your-openai-key

# LLM Configuration
PRIMARY_MODEL=deepseek/deepseek-chat
FALLBACK_MODEL=openai/gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=8192
LLM_TIMEOUT=120

# Server
HOST=0.0.0.0
PORT=8000

# Workspace paths
WORKSPACE_ROOT=../workspace
