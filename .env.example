# LLM API Keys（LiteLLM 根据 model 前缀自动匹配；至少配一个）
DEEPSEEK_API_KEY=sk-your-deepseek-key
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# 默认模型（所有 Agent 的兜底，未被 per-agent 覆盖时使用）
PRIMARY_MODEL=deepseek/deepseek-chat

# ── 每个 Agent 独立模型（为空=用 PRIMARY_MODEL）──
# 概要设计 Agent：推荐用本地部署的 Qwen 小模型（省钱、可用）
DESIGN_MODEL=openai/qwen-input
# 代码生成 Agent：推荐用 DeepSeek（性价比高）
CODEGEN_MODEL=deepseek/deepseek-chat
# 单元测试 Agent：推荐用能力强的模型
TEST_MODEL=deepseek/deepseek-chat

# 本地 Qwen vLLM 地址（仅 DESIGN_MODEL 使用 openai/qwen-input 时生效）
QWEN_VLLM_API_BASE=http://127.0.0.1:8001/v1

# LLM 公共参数
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=8192
LLM_TIMEOUT=120

# Server（端口由 run.sh 随机分配，test_mode 与生产无关）
HOST=0.0.0.0

# Workspace
WORKSPACE_ROOT=../workspace
